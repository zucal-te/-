<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.interview.mapper.UserMapper">
    <insert id="insertUser" parameterType="com.example.interview.entity.User">
        INSERT INTO user (user_id, username, password, create_time)
        VALUES (#{userId}, #{username}, #{password}, NOW())
    </insert>

    </mapper>
